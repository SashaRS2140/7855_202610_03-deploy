# ============================================================================
# FLASK CONFIGURATION - REQUIRED FOR PRODUCTION
# ============================================================================
# SECRET_KEY is used to sign session tokens and CSRF tokens.
# If not set, the app will fail to start (fail-loud design).
# SECURITY: Must be a secure random string, minimum 32 characters.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CRITICAL: DO NOT use the same key across development and production.
FLASK_SECRET_KEY=your_secure_random_key_min_32_chars_here

# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
# Firebase Web API Key for client authentication
FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# Path to Firebase service account key file (for admin SDK)
# SECURITY: Keep this file secret, do not commit to git
FIREBASE_SERVICE_ACCOUNT=serviceAccountKey.json

# Firebase Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# ============================================================================
# API KEY CONFIGURATION - CUBE DEVICE COMMUNICATION
# ============================================================================
# API key for ESP32 CUBE device authentication
# SECURITY: This is a shared secret with the physical device
# CRITICAL: Keep this secret, do not commit to git, use strong random value
CUBE_API_KEY=your_cube_device_api_key_here

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Application type - determines which routes are registered
# Options: "web" (all routes), "api" (API routes only)
APP_TYPE=web

# Flask environment mode
# Options: development, production
# SECURITY: Must be "production" in production deployment
FLASK_ENV=development

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level - controls verbosity
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. This file is a template. Create .env from .env.example and fill values.
# 2. NEVER commit .env or any file with secrets to git.
# 3. All environment variables marked CRITICAL are required for security.
# 4. Use different keys for development and production.
# 5. Rotate CUBE_API_KEY and FLASK_SECRET_KEY periodically in production.
# 6. Use secrets management (e.g., AWS Secrets Manager) in production.
